{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "endOfLine": "lf",
  "sortImports": true,
  "sortPackageJson": true,
  "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/*.tsbuildinfo"]
}
